{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system (client, farmer, rider, admin)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "farmer", "rider", "admin"] },
        "name": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "role", "name", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A transaction or order placed by a client",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "failed", "cancelled"] },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "items": { "type": "array" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["clientId", "status", "totalAmount", "paymentStatus", "items", "createdAt", "updatedAt"]
    },
    "Produce": {
      "title": "Produce",
      "description": "Produce items available from farmers",
      "type": "object",
      "properties": {
        "farmerId": { "type": "string" },
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "isOrganic": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["farmerId", "name", "stock", "unit", "price", "isOrganic", "createdAt", "updatedAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A farm-to-table recipe",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "array" },
        "carbonSavings": { "type": "string" },
        "instructions": { "type": "array" },
        "yields": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "ingredients", "instructions", "createdAt", "updatedAt"]
    },
    "CommissaryItem": {
      "title": "Commissary Item",
      "description": "Vegetables, condiments, or dressed meats from the commissary/public market.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "supplier": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "category", "supplier", "stock", "unit", "price", "createdAt", "updatedAt"]
    },
    "WorkflowAudit": {
      "title": "Workflow Audit",
      "description": "Simulation documents for workflow debugging.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string" },
        "workflowType": { "type": "string" },
        "workflowStep": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "items": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/workflow_audits/{auditId}": {
      "schema": { "$ref": "#/entities/WorkflowAudit" },
      "description": "Workflow debugging audits."
    },
    "/commissaryItems/{itemId}": {
      "schema": { "$ref": "#/entities/CommissaryItem" },
      "description": "Available items from the commissary."
    },
    "/recipes/{recipeId}": {
      "schema": { "$ref": "#/entities/Recipe" },
      "description": "Standard recipes editable by management."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Global user profiles."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "All transactions/orders in the system."
    },
    "/produce/{produceId}": {
      "schema": { "$ref": "#/entities/Produce" },
      "description": "Available produce from farmers."
    }
  }
}
